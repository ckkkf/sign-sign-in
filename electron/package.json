{
  "name": "sign-sign-in-electron",
  "version": "1.3.1",
  "description": "SignSignIn Electron + Vue3 desktop client",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "pnpm typecheck && electron-vite build",
    "typecheck": "vue-tsc --noEmit -p tsconfig.renderer.json && tsc --noEmit -p tsconfig.node.json",
    "test": "vitest run",
    "dist": "pnpm build && electron-builder"
  },
  "dependencies": {
    "@kousum/semi-icons-vue": "^2.78.0",
    "@kousum/semi-ui-vue": "^2.78.4",
    "axios": "^1.13.2",
    "electron-updater": "^6.6.2",
    "form-data": "^4.0.5",
    "https-proxy-agent": "^7.0.6",
    "lucide-vue-next": "^0.555.0",
    "node-forge": "^1.3.1",
    "sm-crypto": "^0.3.13",
    "vue": "^3.5.25"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/node-forge": "^1.3.14",
    "@vitejs/plugin-vue": "^6.0.1",
    "electron": "^39.2.4",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.4",
    "vitest": "^4.0.13",
    "vue-tsc": "^3.1.5"
  },
  "build": {
    "appId": "cn.ckkk.signsignin",
    "productName": "SignSignIn",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "resources/**/*"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.utilities"
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    }
  }
}
